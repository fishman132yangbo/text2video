{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ViMax: Web Console",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/web_server.py",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "args": [
        "--host",
        "127.0.0.1",
        "--port",
        "7860"
      ]
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal"
    }
  ]
}
